import { useState } from "react";
import {
  Dimensions,
  SafeAreaView,
  ScrollView,
  StatusBar,
  StyleSheet,
  Text,
  TouchableOpacity,
  View,
} from "react-native";

const { width, height } = Dimensions.get("window");

export default function ErrorStateScreen() {
  const [isRetrying, setIsRetrying] = useState(false);
  const [activeError, setActiveError] = useState("network");

  const errorTypes = {
    network: {
      icon: "📡",
      title: "Connection Lost",
      message: "Unable to connect to the internet. Please check your connection and try again.",
      suggestion: "Check your Wi-Fi or mobile data settings",
    },
    server: {
      icon: "🔄",
      title: "Server Issue",
      message: "Something went wrong on our end. We're working to fix it as soon as possible.",
      suggestion: "Please try again in a few minutes",
    },
    search: {
      icon: "🔍",
      title: "Search Failed",
      message: "We couldn't complete your search. This might be due to a temporary issue.",
      suggestion: "Try refining your search or check back later",
    },
  };

  const currentError = errorTypes[activeError as keyof typeof errorTypes];

  const handleRetry = () => {
    setIsRetrying(true);
    setTimeout(() => {
      setIsRetrying(false);
      console.log("Retry attempted");
    }, 1500);
  };

  return (
    <SafeAreaView style={styles.container}>
      <StatusBar barStyle="dark-content" backgroundColor="#FAFAFA" translucent={false} />

      {/* Header */}
      <View style={styles.header}>
        <Text style={styles.headerTitle}>Error States</Text>
        <Text style={styles.headerSubtitle}>Calm & helpful error messages</Text>
      </View>

      {/* Error Type Tabs */}
      <View style={styles.tabContainer}>
        <TouchableOpacity
          style={[styles.tab, activeError === "network" && styles.tabActive]}
          onPress={() => setActiveError("network")}
        >
          <Text style={[styles.tabText, activeError === "network" && styles.tabTextActive]}>
            Network
          </Text>
        </TouchableOpacity>
        <TouchableOpacity
          style={[styles.tab, activeError === "server" && styles.tabActive]}
          onPress={() => setActiveError("server")}
        >
          <Text style={[styles.tabText, activeError === "server" && styles.tabTextActive]}>
            Server
          </Text>
        </TouchableOpacity>
        <TouchableOpacity
          style={[styles.tab, activeError === "search" && styles.tabActive]}
          onPress={() => setActiveError("search")}
        >
          <Text style={[styles.tabText, activeError === "search" && styles.tabTextActive]}>
            Search
          </Text>
        </TouchableOpacity>
      </View>

      <ScrollView contentContainerStyle={styles.scrollContent}>
        {/* Error Card */}
        <View style={styles.errorCard}>
          {/* Error Illustration */}
          <View style={styles.illustrationContainer}>
            <View style={styles.illustrationCircle}>
              <Text style={styles.illustrationIcon}>{currentError.icon}</Text>
            </View>
          </View>

          {/* Error Title */}
          <Text style={styles.errorTitle}>{currentError.title}</Text>

          {/* Helpful Message */}
          <Text style={styles.errorMessage}>{currentError.message}</Text>

          {/* Suggestion */}
          <View style={styles.suggestionContainer}>
            <Text style={styles.suggestionIcon}>💡</Text>
            <Text style={styles.suggestionText}>{currentError.suggestion}</Text>
          </View>

          {/* Retry Button */}
          <TouchableOpacity
            style={[styles.retryButton, isRetrying && styles.retryButtonDisabled]}
            onPress={handleRetry}
            disabled={isRetrying}
          >
            <Text style={styles.retryIcon}>↻</Text>
            <Text style={styles.retryButtonText}>
              {isRetrying ? "Trying again..." : "Try Again"}
            </Text>
          </TouchableOpacity>

          {/* Alternative Action */}
          <TouchableOpacity style={styles.alternateButton}>
            <Text style={styles.alternateButtonText}>Go to Homepage</Text>
          </TouchableOpacity>
        </View>

        {/* Help Tips */}
        <View style={styles.tipsContainer}>
          <Text style={styles.tipsTitle}>✨ Quick fixes to try</Text>
          <View style={styles.tipItem}>
            <Text style={styles.tipBullet}>•</Text>
            <Text style={styles.tipText}>Check your internet connection</Text>
          </View>
          <View style={styles.tipItem}>
            <Text style={styles.tipBullet}>•</Text>
            <Text style={styles.tipText}>Restart the app and try again</Text>
          </View>
          <View style={styles.tipItem}>
            <Text style={styles.tipBullet}>•</Text>
            <Text style={styles.tipText}>Update to the latest version</Text>
          </View>
        </View>

        <View style={styles.bottomSpacer} />
      </ScrollView>
    </SafeAreaView>
  );
}

