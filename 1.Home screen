        </View>

        {/* Featured Destinations Section */}
        <View style={styles.sectionHeader}>
          <Text style={styles.sectionTitle}>Featured Destinations</Text>
          <TouchableOpacity>
            <Text style={styles.seeAllText}>See all →</Text>
