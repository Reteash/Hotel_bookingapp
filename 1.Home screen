      id: "4",
      name: "Ocean Paradise",
      location: "Maldives",
      price: "₹42,999",
      rating: "5.0",
      reviews: "3,421",
      image: "https://images.unsplash.com/photo-1514282401047-d79a71a590e8?w=800&h=600&fit=crop",
      isWishlisted: false,
      featured: false,
