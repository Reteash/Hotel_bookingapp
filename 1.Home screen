              <Text style={styles.recentLocation}>Paris, France</Text>
              <Text style={styles.recentPrice}>₹24,999 / night</Text>
            </View>
            <TouchableOpacity style={styles.recentBookButton}>
              <Text style={styles.recentBookText}>Book</Text>
            </TouchableOpacity>
          </TouchableOpacity>
        </View>

        <View style={styles.bottomSpacer} />
      </ScrollView>
    </SafeAreaView>
  );
