    color: "#666666",
  },

  filterTextActive: {
    color: "#FFFFFF",
  },

  // Notifications Container
  notificationsContainer: {
    paddingHorizontal: 20,
  },

  notificationCard: {
    flexDirection: "row",
    backgroundColor: "#FFFFFF",
    borderRadius: 20,
    padding: 16,
    marginBottom: 12,
    shadowColor: "#000",
    shadowOffset: { width: 0, height: 2 },
    shadowOpacity: 0.04,
    shadowRadius: 8,
    elevation: 2,
  },

  unreadCard: {
    backgroundColor: "#FFFFFF",
    borderLeftWidth: 3,
    borderLeftColor: "#1A1A1A",
  },

  lastCard: {
    marginBottom: 0,
  },

  // Icon Container
  iconContainer: {
    width: 52,
    height: 52,
    borderRadius: 26,
    justifyContent: "center",
    alignItems: "center",
