    color: "#1A1A1A",
    letterSpacing: -0.5,
    marginBottom: 4,
  },

  headerSubtitle: {
    fontSize: 13,
    color: "#666666",
    fontWeight: "500",
  },

  clearAllText: {
    fontSize: 13,
    color: "#1A1A1A",
    fontWeight: "600",
  },

  // Filter Chips
  filterContainer: {
    paddingHorizontal: 20,
    marginBottom: 16,
  },

  filterChip: {
    backgroundColor: "#FFFFFF",
    paddingHorizontal: 18,
    paddingVertical: 8,
    borderRadius: 20,
