export default function ReviewsScreen() {
  const [refreshing, setRefreshing] = useState(false);
  const [selectedFilter, setSelectedFilter] = useState("All");

  const filters = ["All", "5 Star", "4 Star", "3 Star", "2 Star", "1 Star"];

  const reviews = [
    {
      id: "1",
      userName: "Sarah Johnson",
      userAvatar: "https://randomuser.me/api/portraits/women/1.jpg",
      rating: 5,
      date: "March 15, 2024",
      comment: "Absolutely incredible experience! The staff went above and beyond to make our stay memorable. The views of the Eiffel Tower from our room were breathtaking. Highly recommend the breakfast buffet!",
      helpful: 128,
    },
    {
      id: "2",
      userName: "Michael Chen",
      userAvatar: "https://randomuser.me/api/portraits/men/2.jpg",
      rating: 5,
      date: "February 28, 2024",
      comment: "Exceptional service and luxurious accommodations. The location is perfect for exploring Paris. The spa treatments were world-class. Will definitely return!",
      helpful: 94,
    },
    {
      id: "3",
      userName: "Emma Williams",
      userAvatar: "https://randomuser.me/api/portraits/women/3.jpg",
      rating: 4,
      date: "February 10, 2024",
      comment: "A wonderful stay! The room was spacious and beautifully decorated. Only minor issue was the wifi speed, but everything else was perfect. The rooftop bar offers amazing sunset views.",
      helpful: 67,
    },
    {
      id: "4",
      userName: "David Kumar",
      userAvatar: "https://randomuser.me/api/portraits/men/4.jpg",
      rating: 5,
      date: "January 22, 2024",
      comment: "Best hotel experience ever! From check-in to check-out, everything was flawless. The concierge helped us plan our entire Paris itinerary. Can't wait to come back!",
      helpful: 156,
    },
    {
      id: "5",
      userName: "Lisa Anderson",
      userAvatar: "https://randomuser.me/api/portraits/women/5.jpg",
      rating: 4,
      date: "January 5, 2024",
      comment: "Beautiful hotel with excellent amenities. The pool and spa were fantastic. Room service was prompt and delicious. Would definitely stay here again.",
      helpful: 43,
    },
  ];

  const onRefresh = async () => {
    setRefreshing(true);
    await new Promise(resolve => setTimeout(resolve, 1500));
    setRefreshing(false);
  };

  const renderStars = (rating: number) => {
    const stars = [];
    for (let i = 0; i < 5; i++) {
      stars.push(i < rating ? "★" : "☆");
    }
    return stars.join("");
  };

  const averageRating = 4.8;
  const totalReviews = reviews.length;

  return (
    <SafeAreaView style={styles.container}>
      <StatusBar barStyle="dark-content" backgroundColor="#FAFAFA" translucent={false} />

      {/* Header */}
      <View style={styles.header}>
        <TouchableOpacity style={styles.backButton}>
          <Text style={styles.backIcon}>←</Text>
        </TouchableOpacity>
        <Text style={styles.headerTitle}>Guest Reviews</Text>
        <View style={styles.placeholder} />
      </View>

      <ScrollView
        showsVerticalScrollIndicator={false}
        refreshControl={
          <RefreshControl refreshing={refreshing} onRefresh={onRefresh} colors={["#1A1A1A"]} />
        }
      >
        {/* Rating Summary Card */}
        <View style={styles.ratingSummaryCard}>
          <View style={styles.ratingLeft}>
            <Text style={styles.averageRating}>{averageRating}</Text>
            <View style={styles.starsContainer}>
              <Text style={styles.starsText}>{renderStars(Math.floor(averageRating))}</Text>
            </View>
            <Text style={styles.totalReviews}>Based on {totalReviews} reviews</Text>
          </View>

          <View style={styles.ratingRight}>
            <View style={styles.ratingBarItem}>
              <Text style={styles.ratingLabel}>5 ★</Text>
              <View style={styles.ratingBar}>
                <View style={[styles.ratingFill, { width: "85%" }]} />
