                  <View style={styles.detailDot} />
                  <View style={styles.detailItem}>
                    <Text style={styles.detailIcon}>👁️</Text>
                    <Text style={styles.detailText}>{room.view}</Text>
                  </View>
                </View>

                {/* Amenities */}
                <View style={styles.amenitiesContainer}>
                  {room.amenities.slice(0, 4).map((amenity, idx) => (
                    <View key={idx} style={styles.amenityBadge}>
                      <Text style={styles.amenityText}>{amenity}</Text>
                    </View>
                  ))}
                  {room.amenities.length > 4 && (
                    <Text style={styles.moreAmenities}>+{room.amenities.length - 4} more</Text>
                  )}
                </View>

                {/* Select Room Button */}
                <TouchableOpacity
                  style={[
                    styles.selectButton,
                    selectedRoomId === room.id && styles.selectButtonSelected,
                    !room.available && styles.selectButtonDisabled,
                  ]}
                  onPress={() => handleSelectRoom(room.id)}
                  disabled={!room.available}
                >
                  <Text
                    style={[
                      styles.selectButtonText,
                      selectedRoomId === room.id && styles.selectButtonTextSelected,
                    ]}
                  >
                    {selectedRoomId === room.id ? "✓ Selected" : "Select Room"}
                  </Text>
                </TouchableOpacity>
              </View>
            </View>
          ))}
        </View>

        <View style={styles.bottomSpacer} />
      </ScrollView>

      {/* Sticky Book Button */}
      {selectedRoomId && (
        <View style={styles.stickyButtonContainer}>
          <TouchableOpacity style={styles.bookButton} onPress={handleBookNow}>
            <Text style={styles.bookButtonText}>Proceed to Book</Text>
            <Text style={styles.bookButtonPrice}>
              {rooms.find(r => r.id === selectedRoomId)?.price}
            </Text>
          </TouchableOpacity>
        </View>
      )}
    </SafeAreaView>
  );
}

