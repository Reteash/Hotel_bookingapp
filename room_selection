                    <Text style={styles.originalPrice}>{room.originalPrice}</Text>
                  </View>
                </View>

                {/* Capacity & Details */}
                <View style={styles.detailsRow}>
                  <View style={styles.detailItem}>
                    <Text style={styles.detailIcon}>👥</Text>
                    <Text style={styles.detailText}>{room.capacity}</Text>
