          {/* Friendly Text */}
          <Text style={styles.emptyTitle}>{currentEmptyState.title}</Text>
          <Text style={styles.emptyMessage}>{currentEmptyState.message}</Text>

          {/* CTA Button */}
          <TouchableOpacity style={styles.primaryButton}>
            <Text style={styles.primaryButtonText}>{currentEmptyState.buttonText}</Text>
          </TouchableOpacity>

          {/* Secondary Button (if available) */}
          {currentEmptyState.secondaryButton && (
            <TouchableOpacity style={styles.secondaryButton}>
              <Text style={styles.secondaryButtonText}>{currentEmptyState.secondaryButton}</Text>
            </TouchableOpacity>
          )}
        </View>

        {/* Additional Info */}
        <View style={styles.infoContainer}>
          <Text style={styles.infoTitle}>💡 Need help finding hotels?</Text>
          <Text style={styles.infoText}>Try searching for popular destinations or check our recommendations</Text>
        </View>

        <View style={styles.bottomSpacer} />
      </ScrollView>
    </SafeAreaView>
